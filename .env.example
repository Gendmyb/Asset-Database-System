# Asset Database System — 环境变量模板
# 复制为 .env 并填入真实值 (不提交到 Git)
# 完整说明见 docs/DEPLOYMENT.md

# === 服务端 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# === PostgreSQL ===
# 应用用 DB_* 变量拼装连接串 (DATABASE_URL 不被读取)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assetdb
DB_USER=app_user
DATABASE_PASSWORD=changeme
# sslmode: 生产建议 require 或 verify-full
DB_SSLMODE=disable

# === JWT ===
# 64 位十六进制 Ed25519 种子; 留空则每次启动随机生成 (会令所有已签发 token 失效, 全员掉线)
# 生成: openssl rand -hex 32
JWT_ED25519_SEED=

# === 运行模式 ===
# DEMO=true 使用内存存储, 无需 PostgreSQL (功能冻结, 仅用于演示)
DEMO=false
