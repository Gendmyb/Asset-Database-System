# Asset Database System — 环境变量模板
# 复制为 .env 并填入真实值 (不提交到 Git)
# 完整说明见 docs/DEPLOYMENT.md

# === 服务端 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# 外部可访问的完整 URL (用于二维码生成等场景, 留空禁用 URL 模式)
EXTERNAL_URL=

# === PostgreSQL ===
# 应用用 DB_* 变量拼装连接串 (DATABASE_URL 不被读取)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assetdb
DB_USER=app_user
DATABASE_PASSWORD=changeme
# sslmode: 生产建议 require 或 verify-full
DB_SSLMODE=disable

# === JWT ===
# 64 位十六进制 Ed25519 种子; 留空则每次启动随机生成 (会令所有已签发 token 失效, 全员掉线)
# 生成: openssl rand -hex 32
JWT_ED25519_SEED=

# === 运行模式 ===
# DEMO=true 使用内存存储, 无需 PostgreSQL (功能冻结, 仅用于演示)
DEMO=false

# ============================================================
# AD/LDAP 集成 (Wave 1 G1 + Wave 3 增强)
# ============================================================
# 以下变量全部配置后 LDAP 才启用; 任一缺失则系统以纯本地模式运行
# LDAP_HOST=ldap.corp.local
# LDAP_PORT=389
# LDAP_USE_TLS=false
# LDAP_USE_SSL=false
# LDAP_BIND_DN=cn=svc_asset,ou=ServiceAccounts,dc=corp,dc=local
# LDAP_BIND_PASSWORD=changeme
# LDAP_BASE_DN=dc=corp,dc=local
# LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName=%s))

# LDAP 属性映射 (默认值匹配 AD 标准属性, 无需修改)
# LDAP_ATTR_USERNAME=sAMAccountName
# LDAP_ATTR_DISPLAY_NAME=displayName
# LDAP_ATTR_EMAIL=mail
# LDAP_ATTR_DN=distinguishedName
# LDAP_ATTR_ORG=department

# 离职处理: true=仅禁用不软删除, false=软删除 (默认)
# LDAP_SYNC_DISABLE_ONLY=false

# === Wave 3: 企业化同步控制 ===
# 分页大小 (ControlPaging), AD MaxPageSize 通常 1000; 默认 500
# LDAP_PAGE_SIZE=500
# 递归展开组成员 (true=含嵌套组, false=仅直接成员, 默认)
# LDAP_SYNC_RECURSIVE=false
# 同步时自动链接同名本地账号 (保留 id/角色/历史; 默认 false=跳过冲突)
# LDAP_LINK_EXISTING=false
# 组成员属性名 (默认 memberOf)
# LDAP_GROUP_ATTR=memberOf

# ============================================================
# 调度器 (Wave 1 G4)
# ============================================================
# 扫描间隔: "off"(默认/不启动) / "30m" / "1h" / "24h" / 纯数字秒
# SCHEDULER_INTERVAL=off
# 质保临近到期阈值 (天), 默认 30
# SCHEDULER_WARRANTY_DAYS=30
# 是否在调度循环中执行 LDAP 同步
# SCHEDULER_LDAP_SYNC=false

# ============================================================
# 通知渠道 (Wave 2 G6) — 全部默认关闭
# ============================================================
# 总开关, false 时不投递任何通知
# NOTIFY_ENABLE=false
# SMTP 邮件
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# 机器人 Webhook (系统级, 单条; admin 可在 notify_rules 里按事件粒度配置)
# NOTIFY_DINGTALK_WEBHOOK=
# NOTIFY_WECOM_WEBHOOK=
# NOTIFY_FEISHU_WEBHOOK=

# ============================================================
# 行级数据权限 (Wave 2 G9)
# ============================================================
# true=启用部门级可见范围 (manager 仅见本部门及子孙部门)
# DATA_SCOPE_DEPARTMENT=false

