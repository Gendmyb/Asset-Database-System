# Asset Database System — 环境变量模板
# 复制为 .env 并填入真实值 (不提交到 Git)

# === 服务端 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# === PostgreSQL ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assetdb
DB_USER=app_writer
DATABASE_PASSWORD=changeme

# === Redis ===
REDIS_ADDR=localhost:6379
REDIS_MASTER=mymaster
REDIS_PASSWORD=

# === Vault / KMS ===
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# === Agent ===
AGENT_SERVER_URL=https://asset-db.internal
AGENT_MTLS_CERT=/etc/agent/client.crt
AGENT_MTLS_KEY=/etc/agent/client.key
AGENT_CA_CERT=/etc/agent/ca.crt
